# 服务端口
PORT=3000

# 运行环境
NODE_ENV=development

# 时区
TZ=Asia/Shanghai

# 日志级别（trace/debug/info/warn/error/fatal）
LOG_LEVEL=info

# API 鉴权密钥（不配置则跳过鉴权）
API_KEY=

# CORS 允许的源
CORS_ORIGIN=*

# Puppeteer 配置
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage

# 缓存配置
CACHE_MAX_SIZE=100
CACHE_TTL_SECONDS=3600

# 海报尺寸
POSTER_WIDTH=750
POSTER_HEIGHT=1334
