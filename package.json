{
  "name": "tarot-poster-service",
  "version": "1.1.1",
  "description": "塔罗牌海报生成微服务 - HTML/CSS + Puppeteer 截图",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp src/poster/templates/*.html src/poster/templates/*.css dist/poster/templates/",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "pino": "^10.3.1",
    "puppeteer": "^23.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.4.2",
    "vitest": "^2.1.0"
  }
}
